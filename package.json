{
  "name": "medusa-payment-hyperswitch",
  "version": "0.1.1",
  "description": "HyperSwitch payment processor plugin for Medusa v2 — unified checkout, webhooks, refunds, and admin configuration.",
  "author": "Juspay (https://hyperswitch.io)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ayyanaruto/hyperswitch-medusajs-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/Ayyanaruto/hyperswitch-medusajs-plugin/issues"
  },
  "homepage": "https://github.com/Ayyanaruto/hyperswitch-medusajs-plugin#readme",
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "medusa-plugin-integration",
    "medusa-plugin-other",
    "hyperswitch",
    "juspay",
    "payment",
    "payment-provider",
    "ecommerce"
  ],
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "prepublishOnly": "medusa plugin:build"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "https-proxy-agent": "^7.0.5",
    "lucide-react": "^0.460.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/cli": "2.4.0",
    "@medusajs/framework": "2.15.5",
    "@medusajs/icons": "2.4.0",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/test-utils": "2.4.0",
    "@medusajs/ui": "4.0.4",
    "@mikro-orm/cli": "6.4.3",
    "@mikro-orm/core": "6.4.3",
    "@mikro-orm/knex": "6.4.3",
    "@mikro-orm/migrations": "6.4.3",
    "@mikro-orm/postgresql": "6.4.3",
    "@swc/core": "1.5.7",
    "@tanstack/react-query": "4.22",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "awilix": "^8.0.1",
    "pg": "^8.13.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": ">=2.15.0",
    "@medusajs/cli": ">=2.4.0",
    "@medusajs/framework": ">=2.15.0",
    "@medusajs/icons": ">=2.4.0",
    "@medusajs/medusa": ">=2.15.0",
    "@medusajs/test-utils": ">=2.4.0",
    "@medusajs/ui": ">=4.0.3",
    "@mikro-orm/cli": "6.4.3",
    "@mikro-orm/core": "6.4.3",
    "@mikro-orm/knex": "6.4.3",
    "@mikro-orm/migrations": "6.4.3",
    "@mikro-orm/postgresql": "6.4.3",
    "awilix": "^8.0.1",
    "pg": "^8.13.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4"
}
